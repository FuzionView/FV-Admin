<h1>Feature statuses</h1>
<div id="feature_status">
  <table class="table">
    <thead>
      <tr>
        <th>Id</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% @feature_statuses.each do |feature_status| %>
        <tr>
          <td><%= feature_status.id %></td>
          <td><%= feature_status.status %></td>
          <td>
             <%= link_to 'Edit', edit_feature_status_path(feature_status) %>
             <%= button_to "Delete", feature_status, method: :delete, class: 'btn btn-outline-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>


<%= link_to "New feature status", new_feature_status_path %>
