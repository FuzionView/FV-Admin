<h1><%= @owner.name %>: New dataset</h1>

<%= simple_form_for(@dataset, url: @url, data: { turbo: false }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>
  <p>Enter the name and URL of your dataset. ESRIJSON and WFS are supported.
  Use a 'WFS:' prefix before WFS dataset urls. ESRIJON Sources should
  start with http(s). <%= link_to 'Basic dataset entry', new_owner_dataset_path(@owner) %></p>

  <div class="row">
    <div class="col-6 col-md-8 col-sm-12">
      <div class="form-inputs">
        <%= f.input :name, as: :string %>
        <% if f.object.source_dataset.present? && !f.object.source_error.present? %>
          <div class='mb-1'>Source Dataset:</div>
           <%= f.hidden_field :source_dataset %>
           <p><%= f.object.source_dataset %></p>
        <% else %>
          <%= f.input :source_dataset, as: :string,
            hint: 'The URL for the source ESRI or WFS.' %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <%= f.button :submit, 'Submit', class: 'btn btn-primary' %>
  </div>
<% end %>

<br>

<div>
  <%= link_to "Back to data provider", owner_path(@dataset.owner_id) %>
</div>
