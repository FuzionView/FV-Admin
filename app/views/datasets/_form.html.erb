<%= simple_form_for(@dataset, url: url, data: { turbo: false }) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="row">
    <div class="col-6 col-md-8 col-sm-12">
      <div class="form-inputs">
        <%= f.input :name, as: :string %>
          <%= f.input :source_dataset, as: :string,
            hint: 'The URL for the source ESRI or WFS.' %>
          <%= f.input :source_sql, input_html: { rows: 15 } %>
          <%= f.input :source_co_v, input_html: { value: f.object.source_co&.join(',') } %>
          <%= f.input :cache_whole_dataset, as: :boolean %>
          <%= f.input :enabled, as: :boolean %>
          <%= f.input :source_srs, as: :string, hint: 'The EPSG code for the coordinate system' %>
        <%# f.input :owner_id, as: :hidden %>
      </div>
    </div>
  </div>

  <div class="form-actions">
    <%= f.button :submit, 'Submit', class: 'btn btn-primary' %>
  </div>
<% end %>
