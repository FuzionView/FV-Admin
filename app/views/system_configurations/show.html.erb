<h1>
  System Configuration Key: <%= @system_configuration.key %>
  <span class="float-end">
    <%= edit_link('Edit', edit_system_configuration_path(@system_configuration)) %>
  </span>
</h1>

<div class="container">
  <div class="row">
    <div class="col-2">
      Value:
    </div>
    <div class="col">
      <%= @system_configuration.value %>
    </div>
  </div>
</div>
<div class="pt-3">
  <%= link_to "Back to system settings", system_settings_path %>
</div>

